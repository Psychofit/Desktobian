{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Desktobian",
  "version": "0.1.0",
  "identifier": "org.desktobian.gui",
  "build": {
    "frontendDist": "frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Desktobian — Wallpaper Manager",
        "width": 1040,
        "height": 720,
        "minWidth": 820,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
