[Unit]
Description=Desktobian animated wallpaper engine
Documentation=https://github.com/psychofit/desktobian
# Start once the graphical session is up.
PartOf=graphical-session.target
After=graphical-session.target

[Service]
Type=simple
# Reads ~/.config/desktobian/config.toml. Pass --source or -b here to override.
ExecStart=%h/.local/bin/desktobian run
Restart=on-failure
RestartSec=2

[Install]
WantedBy=graphical-session.target
